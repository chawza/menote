{
  "languages": {
    "CSS": {
      "tab_size": 2,
      "hard_tabs": false,
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      }
    },
    "HTML": {
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      }
    },
    "JSON": {
      "tab_size": 2,
      "hard_tabs": false,
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      }
    },
    "JSONC": {
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      }
    },
    "JavaScript": {
      "tab_size": 2,
      "hard_tabs": false,
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "JSX": {
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      },
      "code_actions_on_format": {
